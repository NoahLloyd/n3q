{
  "expo": {
    "name": "N3Q",
    "slug": "n3q",
    "owner": "n3q",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "n3q",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.n3q.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.n3q.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow N3Q to use your camera to scan QR codes for login."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow N3Q to add events to your calendar."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/cdb8a70f-0945-45dc-89d1-f358e5a80009"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cdb8a70f-0945-45dc-89d1-f358e5a80009"
      }
    }
  }
}
